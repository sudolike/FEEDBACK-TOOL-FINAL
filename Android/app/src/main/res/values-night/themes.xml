<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.FeedbackTool" parent="android:Theme.Material.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
    </style>

    <style name="Theme.FeedbackTool.Splash" parent="Theme.FeedbackTool">
        <item name="android:windowSplashScreenBackground" tools:targetApi="s">#0F172A</item>
        <item name="android:windowSplashScreenAnimatedIcon" tools:targetApi="s">@drawable/ic_logo</item>
        <item name="android:windowSplashScreenIconBackgroundColor" tools:targetApi="s">#0F172A</item>
    </style>
</resources>

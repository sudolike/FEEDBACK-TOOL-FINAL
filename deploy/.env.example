# 复制本文件为 .env，按需修改后再运行 docker compose

# ---- 数据库 ----
DB_NAME=feedback_1
DB_PASSWORD=feedback123
DB_PORT_HOST=3307

# ---- Redis ----
REDIS_PORT_HOST=6380

# ---- 后端 ----
BACKEND_PORT_HOST=9091

# ============================================
# ---- AI Provider 配置 ----
# 支持两种 provider：dashscope / pai-eas，二选一
# ============================================

# 1) 默认：阿里云通义千问 DashScope
#    需要在 https://dashscope.console.aliyun.com 申请 API Key
AI_PROVIDER=dashscope
AI_API_KEY=
AI_MODEL=qwen-plus

# 2) 备选：阿里云 PAI EAS 自部署模型
#    把 AI_PROVIDER 改成 pai-eas 后，下面三个变量必填
# AI_PROVIDER=pai-eas
# AI_EAS_ENDPOINT=http://<id>.cn-hangzhou.pai-eas.aliyuncs.com/api/predict/agent_api
# AI_EAS_TOKEN=
# AI_EAS_MODEL=default
# AI_EAS_MODE=openai      # openai（默认，OpenAI 兼容 v1/chat/completions）/ predict（原生 predict）
# AI_EAS_TIMEOUT_MS=120000

# ---- 邮件（可留空） ----
MAIL_USERNAME=
MAIL_PASSWORD=
